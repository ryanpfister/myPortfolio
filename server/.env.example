# Copy to .env on your VPS and fill in real values.
# Never commit .env to git.

# Listen port (nginx will proxy /api/* and /blog/* to this)
PORT=3000

# Admin credentials.
# 1. Pick a username (anything you'll remember).
# 2. Generate a bcrypt hash for your password by running:
#      node hash.js "your-real-password"
#    then paste the output here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$REPLACE_ME_WITH_OUTPUT_OF_HASH_SCRIPT

# JWT signing secret. Generate a random 32+ char string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_ME_WITH_RANDOM_HEX_STRING

# Where the SQLite file lives. Default keeps it next to server code.
# In production prefer somewhere outside the repo so git pull never touches it.
DB_PATH=./portfolio.db

# Comma-separated origins allowed to call the API (CORS). Usually just yours.
ALLOWED_ORIGINS=https://rdpfister.com,https://www.rdpfister.com

# Cookie domain (for the auth JWT cookie). Set to your domain in prod.
COOKIE_DOMAIN=rdpfister.com
COOKIE_SECURE=true

# Set NODE_ENV=production on the VPS.
NODE_ENV=development
